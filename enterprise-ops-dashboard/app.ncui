// Enterprise UI â€” generated by NC AI

page "Enterprise"

style:
    background is "#0a0a0f"
    text color is "#e0e0e8"
    accent is "#00d4ff"
    font is "Inter, system-ui, sans-serif"

nav:
    brand "Enterprise"
    links:
        link "Dashboard" to "#dashboard"
        link "Tenants" to "#tenants"
        link "Roles" to "#roles"
        link "Analytics" to "#analytics"
        link "Approvals" to "#approvals"
        link "Alerts" to "#alerts"

header:
    row:
        heading "Enterprise" size 1
        spacer
        button "Login" action login
        button "Sign Up" action signup style primary

section "Dashboard":
    row:
        card:
            heading "Total Enterprises" size 3
            text "{{count}}" size large
        card:
            heading "Active" size 3
            text "{{active_count}}" size large
        card:
            heading "Today" size 3
            text "{{today_count}}" size large

    row:
        card:
            heading "Pending Approvals" size 3
            text "{{pending_approvals}}" size large
        card:
            heading "Active Alerts" size 3
            text "{{active_alerts}}" size large
        card:
            heading "Automation Success" size 3
            text "{{automation_success}}%" size large

section "Tenants":
    list from "/api/v1/tenants" as tenants:
        card:
            heading "{{tenants.name}}" size 3
            text "Status: {{tenants.status}}"

section "Roles":
    card:
        heading "Role Access" size 3
        list:
            item "Admin — approvals, analytics, alerts"
            item "Approver — approvals, alerts"
            item "Viewer — analytics"

section "Analytics":
    grid 3 columns:
        card:
            heading "Tenant Throughput" size 3
            text "42 ops/min"
        card:
            heading "Approval SLA" size 3
            text "98% within target"
        card:
            heading "Escalations" size 3
            text "2 active"

section "Approvals":
    list from "/api/v1/approvals" as approvals:
        card:
            heading "{{approvals.title}}" size 3
            text "Requested by {{approvals.requested_by}}"
            row:
                button "Approve" action approve_item style primary
                button "Reject" action reject_item style danger

section "Alerts":
    list from "/api/v1/alerts" as alerts:
        card:
            heading "{{alerts.severity}} alert" size 3
            text "{{alerts.message}}"
            button "Acknowledge" action acknowledge_alert style secondary

section "Enterprises":
    input "Search enterprises..." bind search_query on-change search

    list from enterprises:
        card:
            heading "{{item.name}}" size 3
            text "{{item.description}}"
            row:
                button "Edit" action edit_item
                button "Delete" action delete_item style danger

section "Add Enterprise":
    form:
        input "Name" bind new_name required
        input "Description" bind new_description
        button "Create Enterprise" action create_item style primary

footer:
    text "Built with NC" color muted
    link "API Docs" href "/docs"

actions:
    on create_item:
        post "/enterprises" with {name: new_name, description: new_description}
        reload enterprises
    on delete_item:
        delete "/enterprises/{{item.id}}"
        reload enterprises
    on search:
        get "/enterprises/search/{{search_query}}"
    on approve_item:
        post "/api/v1/approvals/{{item.id}}/approve"
        reload approvals
    on reject_item:
        post "/api/v1/approvals/{{item.id}}/reject"
        reload approvals
    on acknowledge_alert:
        post "/api/v1/alerts/{{item.id}}/ack"
        reload alerts
    on login:
        navigate "/login"
    on signup:
        navigate "/signup"

data:
    enterprises from "/enterprises"
    tenants from "/api/v1/tenants"
    roles from "/api/v1/roles"
    analytics from "/api/v1/analytics/overview"
    approvals from "/api/v1/approvals"
    alerts from "/api/v1/alerts"
