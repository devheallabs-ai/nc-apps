page "DevHeal Labs AI — Developer Portal"
theme "dark"
accent "#6366f1"
font "Inter"

nav:
    brand "DevHeal Labs AI"
    links:
        link "Products" to "#products"
        link "NC Language" to "#nc-language"
        link "NC AI" to "#nc-ai"
        link "Docs" to "#docs"
        link "Try NC" to "#playground"

section products:
    heading "AI-Driven Development Platform"
    text "Build backends, frontends, and AI services with plain English. No boilerplate. No frameworks. Just NC."

    grid 3 columns:
        card icon "rocket":
            heading "NC Language"
            stat "Backend" "Plain English → APIs"
            text "Write server-side logic in natural English. Deploy in seconds."
            button "Try NC" style "primary"
        card icon "globe":
            heading "NC UI"
            stat "Frontend" "Plain English → Web Apps"
            text "Build beautiful web interfaces with plain text. No HTML/CSS expertise needed."
            button "Try NC UI" style "primary"
        card icon "shield":
            heading "NC AI"
            stat "Intelligence" "Natural Language → AI Services"
            text "Add AI to any service with one line. Built-in LLM bridge, training, inference."
            button "Try NC AI" style "primary"
    animate "stagger"

    grid 2 columns:
        card icon "users":
            heading "HiveANT"
            stat "Autonomous Incident Response"
            text "12 AI agents that automatically detect, investigate, and fix production incidents."
            button "Learn More" style "secondary"
        card icon "chart":
            heading "SwarmOps"
            stat "AI Operations Intelligence"
            text "Self-healing operations platform. AI monitors, investigates, and resolves issues."
            button "Learn More" style "secondary"
    animate "fade-up"

section nc-language:
    heading "NC Language"
    text "The world's first AI-native programming language. Write code in plain English."

    grid 3 columns:
        card icon "rocket":
            heading "Simple"
            text "Write 'ask AI to classify this' and it works. No SDK, no config, no boilerplate."
        card icon "shield":
            heading "Powerful"
            text "Built-in HTTP, WebSockets, databases, authentication, and AI — all native features."
        card icon "clock":
            heading "Fast"
            text "570KB binary, zero dependencies, C11 runtime. Compiles to optimized bytecode."
    animate "stagger"

    card:
        heading "Write This Instead of 50 Lines of Python"
        text "Traditional Python: 50+ lines. Flask setup, OpenAI SDK, JSON parsing, error handling..."
        text "NC Language — 8 lines:"
        list:
            item "service \"classifier\" / version \"1.0.0\""
            item "configure: ai_model is \"default\""
            item "to classify with text:"
            item "    ask AI to \"classify sentiment\" using text save as label"
            item "    respond with {\"label\": label}"
            item "api: POST /classify runs classify"
        button "See Full Comparison" style "secondary"
    animate "fade-up"

    grid 4 columns:
        card:
            heading "Languages Replaced"
            stat "Python / Node / Go" "For AI services"
        card:
            heading "Code Reduction"
            stat "80-90%" "Less code to write"
        card:
            heading "Binary Size"
            stat "570 KB" "Zero dependencies"
        card:
            heading "Startup Time"
            stat "<50ms" "Cold start"
    animate "stagger"

section nc-ai:
    heading "NC AI — AI Written in NC"
    text "The NC AI model itself is written in NC — not C, not Python. NC all the way down."

    grid 3 columns:
        card icon "rocket":
            heading "NC Transformer"
            stat "Written in NC" "Decoder-only transformer"
            text "Model architecture defined in NC. Engine handles math."
        card icon "shield":
            heading "NC Tokenizer"
            stat "Written in NC" "BPE tokenization"
            text "NC-specific vocabulary. Encodes/decodes NC source code."
        card icon "clock":
            heading "NC Optimizer"
            stat "Written in NC" "Adam optimizer"
            text "Training loop, gradient clipping, LR scheduling — all NC."
    animate "stagger"

    card:
        heading "Architecture Philosophy"
        text "Engine (C) handles: VM, compiler, tensor math — like CPython handles Python."
        text "NC handles: model logic, training, inference, APIs, tests, scripts — everything else."
        text "Just like PyTorch: Python defines the model, C++ handles the math. NC defines the model, the C engine handles the math."
        button "View NC AI Source" style "primary"
        button "Start Training" style "secondary"
    animate "fade-up"

section docs:
    heading "Get Started in 60 Seconds"
    text "Install NC and write your first AI service immediately"

    grid 3 columns:
        card:
            heading "1. Install NC"
            list:
                item "macOS: curl -fsSL install.nc.devheallabs.in | bash"
                item "Windows: Download nc.exe from releases"
                item "Linux: curl -fsSL install.nc.devheallabs.in | bash"
        card:
            heading "2. Write your service"
            list:
                item "Create hello.nc"
                item "service \"hello\" / version \"1.0.0\""
                item "to greet:"
                item "    respond with \"Hello NC!\""
                item "api: GET /hello runs greet"
        card:
            heading "3. Run it"
            list:
                item "nc serve hello.nc"
                item "Open http://localhost:8000/hello"
                item "See: Hello NC!"
                item "That's it — zero config needed"
    animate "stagger"

    grid 2 columns:
        card:
            heading "Documentation"
            list:
                item "NC Language Reference"
                item "NC UI Components Guide"
                item "NC AI Integration Guide"
                item "HiveANT Setup Guide"
                item "SwarmOps Configuration"
            button "View All Docs" style "secondary"
        card:
            heading "Examples"
            list:
                item "Hello World Service"
                item "REST CRUD API"
                item "AI Classifier"
                item "Chat Assistant with Memory"
                item "Stock Market Dashboard"
            button "Browse Examples" style "primary"
    animate "fade-up"

section playground:
    heading "Try NC Right Now"
    text "Generate NC code from plain English — no install required"

    form action "/api/generate":
        input "Describe what you want to build..." required
        button "Generate NC Code" style "primary"
    animate "fade-up"

    card:
        heading "Example Prompts"
        list:
            item "create a REST API for a todo list"
            item "build an AI sentiment analysis service"
            item "make a chat assistant with memory"
            item "create a stock price monitoring service"
            item "build a content moderation API"
    animate "fade-up"

footer:
    text "DevHeal Labs AI — Building the future of AI-native development"
    row:
        link "NC Language" to "https://nc.devheallabs.in"
        link "NC UI" to "https://ncui.devheallabs.in"
        link "NC AI" to "https://ncai.devheallabs.in"
        link "HiveANT" to "https://hiveant.devheallabs.in"
        link "SwarmOps" to "https://swarmops.devheallabs.in"
        link "GitHub" to "#"
        link "Contact" to "#"
